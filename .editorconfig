# EditorConfig for codemod-pilot
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Rust source files
[*.rs]
indent_size = 4
max_line_length = 100

# TOML configuration
[*.toml]
indent_size = 4

# YAML configuration
[*.{yml,yaml}]
indent_size = 2

# Markdown documentation
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# GitHub templates
[.github/**]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
